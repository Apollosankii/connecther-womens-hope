# Supabase (required – Admin Portal connects directly, no FastAPI)
# Use the SAME project as the Android app.
# Shared credentials live in woman-global/.env; portal-specific overrides go here.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional: service role key (Dashboard → Settings → API). Server-side only; never expose to browsers.
# - Signs private URLs for some document flows.
# - If unset: service catalog uploads use your signed-in admin JWT + RLS (policy ``service_catalog_admin_all``
#   in migration ``woman-global/supabase/migrations/20260430140000_service_catalog_storage_bucket.sql``).
# - If set: uploads and service PATCH can use the role key (useful when JWT/RLS is misconfigured).
# Never commit real keys.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Clerk (optional – Admin Portal can use Clerk for sign-in alongside Supabase Auth)
# Same Clerk app as Android. JWT template "supabase" required in Clerk Dashboard.
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# Optional: show detailed 500 errors when developing.
# FLASK_DEBUG=1

# Server-side Flask sessions (large Clerk→Supabase JWTs exceed cookie size ~4KB otherwise).
# The app auto-enables filesystem sessions under .flask_session/ when that folder is writable.
# Override path or force classic cookie-only session:
# FLASK_SESSION_FILE_DIR=/var/lib/connecther-admin-sessions
# FLASK_COOKIE_SESSION_ONLY=1

# Production (e.g. Vercel): set a random secret for session cookies.
# FLASK_SECRET_KEY=your-random-secret-from-openssl-rand-hex-32
