# OS / IDE
.DS_Store
Thumbs.db
*.swp

# Secrets (never commit)
.env
**/.env
**/.env.*
!**/.env.example
# Firebase / Google Cloud service account private keys (GitHub push protection blocks these).
# App google-services.json is different and may stay tracked as non-secret client config.
**/firebase_service_account.json
**/firebaseKey.json

# Android / Gradle
**/local.properties
**/.gradle/
**/build/
**/captures/
**/.cxx/
**/.externalNativeBuild/
# Never commit heap dumps, release APKs, or local log dumps (they break pushes and blow repo size)
*.hprof
**/app/release/*.apk
**/latest-logcat.txt

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Node
node_modules/

# Logs / local dev
debug.log
*.log
.cursor/

# Supabase CLI local
.supabase/

# MCP / deploy temp files
**/.mcp_*
**/.paystack_*
**/_args_line.txt

# IntelliJ / Android Studio module files
*.iml

# Temporary SQL / query files
query_raw_for_mcp.sql
