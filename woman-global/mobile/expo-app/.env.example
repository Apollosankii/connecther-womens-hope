EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Firebase Web SDK config (from Firebase Console)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional: Google OAuth client IDs (Web ID defaults to Android `default_web_client_id` if unset)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Required by expo-auth-session on native; if empty, app falls back to Web client ID (dev only — add real Android OAuth client for production)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Expo AuthSession proxy (HTTPS redirect for Google Web OAuth in Expo Go). Prefer `npx expo login` + EXPO_PUBLIC_EXPO_OWNER, or set the full name:
# EXPO_PUBLIC_EXPO_OWNER=your_expo_username
# EXPO_PUBLIC_EXPO_AUTH_PROXY_FULL_NAME=@your_expo_username/connecther

