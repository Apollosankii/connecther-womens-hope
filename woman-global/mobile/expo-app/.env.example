# Optional: JDK for Gradle when `JAVA_HOME` is wrong or unset (must contain bin/java). Used at prebuild → android/gradle.properties.
# EXPO_ANDROID_JAVA_HOME=C:\Program Files\Android\Android Studio\jbr
# Optional: Android SDK root when `ANDROID_HOME` is unset. Used at prebuild → android/local.properties.
# EXPO_ANDROID_SDK_ROOT=C:\Users\YourName\AppData\Local\Android\Sdk

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Firebase Web SDK config (from Firebase Console)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Native Google Sign-In + Firebase: Web application OAuth client ID (same as Android `default_web_client_id` / Firebase Web client).
# If unset, a development default may be used from AppConfig — set explicitly for production.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Optional: separate iOS OAuth client ID from Google Cloud (iOS type). When set and different from the Web ID, it is passed to GoogleSignin.configure().
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Optional: legacy / unused by native Google Sign-In; kept for compatibility with older docs.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# RevenueCat public SDK key (iOS App Store subscriptions). Android uses Paystack, not RevenueCat.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=

# Supabase Edge secret (set in Supabase dashboard, not in the app): REVENUECAT_WEBHOOK_SECRET

# Optional: Expo account owner string (e.g. for EAS). Not required for native Google Sign-In.
# EXPO_PUBLIC_EXPO_OWNER=your_expo_username

# EAS / store builds (used by app.config.ts at build time; not required for local dev)
# After `eas init`, set one of these to your Expo project UUID:
# EAS_PROJECT_ID=
# EXPO_PUBLIC_EAS_PROJECT_ID=
# Increment per release when shipping to stores:
# ANDROID_VERSION_CODE=1
# IOS_BUILD_NUMBER=1

# Push (Android FCM): `google-services.json` must exist in expo-app/ (copied from woman-global/mobile/android/app/).
# After changing app.config.ts plugins or google-services.json, rebuild the dev client: npx expo run:android

