# Copy to keystore.properties. Do not commit keystore.properties.
#
# Play rejects uploads when the AAB is signed with a different key than the one registered
# as your upload key. Example error:
#   expected SHA1: E6:56:A9:CC:8B:3B:58:7B:D4:C2:FA:DB:73:F7:BC:C4:90:C6:6A:67
#   but your file was signed with SHA1: D4:76:14:0E:7C:94:7C:92:0E:C3:DA:72:5B:10:34:D1:01:D1:60:E4
# → keystore.properties points at the wrong .keystore (D4:76…). You need the file that shows E6:56…
#
# Check what a keystore will sign with:
#   keytool -list -v -keystore YOUR_FILE.keystore -alias YOUR_ALIAS
# Under "SHA1:" it must match Play Console → Release → Setup → App signing → Upload key certificate.
#
# If you no longer have the E6:56… keystore: Play Console → request an upload key reset (or use
# the key reset flow Google documents for your account).
#
# After fixing keystore.properties, verify Gradle’s release signing:
#   gradlew signingReport
# (look at Variant: release — Signing Config Values / SHA1.)

storeFile=connecther-upload.keystore
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD
