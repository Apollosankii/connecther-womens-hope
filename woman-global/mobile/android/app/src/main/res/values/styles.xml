<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="start_button">
        <item name="android:background">@color/accent_color</item>
        <item name="android:minWidth">150dp</item>
        <item name="android:textColor">#fff</item>
        <item name="android:textSize">20sp</item>
        <item name="android:layout_margin">10dp</item>
        <item name="android:padding">10dp</item>
    </style>

    <style name="main_button" parent="start_button">
        <item name="android:textSize">18sp</item>
        <item name="android:minWidth">150dp</item>
        <item name="android:background">@drawable/main_button_bg</item>

    </style>

    <style name="history_button">
        <item name="android:textSize">12sp</item>
        <item name="minWidth">0dp</item>
        <item name="textAllCaps">false</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">10dp</item>
    </style>

    <style name="display_item">
        <item name="elevation">2dp</item>
        <item name="android:background">@drawable/profile_showcase_layout</item>
    </style>

    <style name="CalendarWeekDayStyle"></style>

    <!-- Bottom nav sits inside MaterialCardView; kill Material’s own surface fill so only the card shows -->
    <style name="Widget.ConnectHer.BottomNavigation.Island" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="elevation">0dp</item>
    </style>

</resources>