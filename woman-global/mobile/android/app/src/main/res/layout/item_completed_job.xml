<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/rounded_card"
    android:layout_margin="8dp">

    <TextView
        android:id="@+id/jobTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Completed Job #1"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black" />

    <TextView
        android:id="@+id/clientName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Client: John Doe"
        android:textSize="14sp"
        android:textColor="@color/black" />

    <TextView
        android:id="@+id/serviceName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Service: Cleaning"
        android:textSize="14sp"
        android:textColor="@color/black" />

    <TextView
        android:id="@+id/jobPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Price: Ksh 2000"
        android:textSize="14sp"
        android:textColor="@color/black" />

    <TextView
        android:id="@+id/jobDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date: 2024-02-28"
        android:textSize="14sp"
        android:textColor="@color/black" />

    <RatingBar
        android:id="@+id/jobRatingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="0.5"
        android:rating="0"
        android:isIndicator="true"
        android:visibility="gone"
        android:secondaryProgressTint="@color/star_yellow"
        style="@style/Widget.AppCompat.RatingBar.Small"/>

    <Button
        android:id="@+id/rateJobButton"
        style="@style/main_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rate Job"
        android:padding="8dp"
        android:backgroundTint="@color/accent_color"
        android:textColor="@color/white"
        android:visibility="gone"/>
</LinearLayout>
