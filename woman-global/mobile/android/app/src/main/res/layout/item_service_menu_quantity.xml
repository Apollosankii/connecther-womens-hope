<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/figma_menu_row_margin_horizontal"
    android:layout_marginTop="@dimen/figma_menu_row_margin_top"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/figma_menu_card_corner"
    app:cardElevation="6dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/figma_menu_thumb_size"
            android:layout_height="@dimen/figma_menu_thumb_size"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="@dimen/figma_menu_thumb_corner"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/imageThumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                tools:src="@mipmap/ic_launcher" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/figma_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Basic House Cleaning" />

            <TextView
                android:id="@+id/textUnitLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/figma_text_muted"
                android:textSize="13sp"
                tools:text="No of bedrooms" />

            <TextView
                android:id="@+id/textPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/figma_text_price"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="KES 500" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonMinus"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="−"
            android:textColor="@color/figma_text_primary"
            android:textSize="18sp"
            app:backgroundTint="@color/qty_minus_bg"
            app:cornerRadius="22dp" />

        <TextView
            android:id="@+id/textQty"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/figma_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonPlus"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="+"
            android:textColor="@color/on_primary"
            android:textSize="18sp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="22dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
