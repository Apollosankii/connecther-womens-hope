<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface"
        android:title="@string/subscriptions_title"
        android:titleTextColor="@color/on_background"
        android:navigationIcon="@drawable/arrow_back_24px" />

    <LinearLayout
        android:id="@+id/activeSubCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:padding="16dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subscriptions_current_plan_section_title"
            android:textColor="@color/on_background"
            android:textSize="12sp"
            android:letterSpacing="0.06"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/activeSubPlan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_background"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/activeSubSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:text="@string/subscriptions_current_plan_subtitle" />

        <TextView
            android:id="@+id/activeSubExpires"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/activeSubConnects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_background"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/plansSectionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="4dp"
        android:text="@string/subscriptions_section_all_plans"
        android:textColor="@color/on_background"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/emptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/subscriptions_empty_plans"
        android:textColor="@color/on_surface_variant"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSubscriptions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="16dp" />

</LinearLayout>
