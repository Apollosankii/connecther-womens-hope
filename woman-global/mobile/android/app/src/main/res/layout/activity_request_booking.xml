<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/chat_thread_background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="128dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="8dp">

                <ImageButton
                    android:id="@+id/buttonBackRequestBooking"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/back"
                    android:padding="8dp"
                    android:src="@drawable/arrow_back_24px"
                    app:tint="@color/figma_text_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/booking_checkout_title"
                    android:textColor="@color/figma_text_primary"
                    android:textSize="20sp" />

                <View
                    android:layout_width="48dp"
                    android:layout_height="48dp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="@dimen/figma_menu_card_corner"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/booking_order_details_title"
                        android:textColor="@color/figma_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textOrderSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/figma_text_muted"
                        android:textSize="13sp"
                        tools:text="House Cleaning · Jane" />

                    <EditText
                        android:id="@+id/inputPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/rounded_edittext"
                        android:hint="@string/booking_proposed_price_hint"
                        android:inputType="numberDecimal"
                        android:padding="12dp"
                        android:textColor="@color/on_background"
                        android:textColorHint="@color/on_surface_variant" />

                    <EditText
                        android:id="@+id/inputLocationNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/rounded_edittext"
                        android:gravity="top"
                        android:hint="@string/booking_field_location_hint"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:padding="12dp"
                        android:textColor="@color/on_background"
                        android:textColorHint="@color/on_surface_variant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonUseCurrentGps"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/booking_use_current_gps_caption"
                        android:textAllCaps="false" />

                    <TextView
                        android:id="@+id/textGpsCoords"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:visibility="gone"
                        tools:text="GPS: -1.29000, 36.82000"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/labelExtraLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/booking_extra_address_section_title"
                        android:textColor="@color/on_background"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/extraLocationFieldsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="vertical"
                        android:visibility="gone" />

                    <EditText
                        android:id="@+id/inputMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/rounded_edittext"
                        android:gravity="top"
                        android:hint="@string/booking_field_message_hint"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:padding="12dp"
                        android:textColor="@color/on_background"
                        android:textColorHint="@color/on_surface_variant" />

                    <TextView
                        android:id="@+id/textLocationHelp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/booking_location_section_body"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/booking_payment_outside_copy"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="@color/surface"
        app:cardElevation="12dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.ConnectHer.ServiceMenuBottomBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingTop="16dp"
            android:paddingBottom="18dp">

            <TextView
                android:id="@+id/textTotalLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/booking_total_placeholder"
                android:textColor="@color/figma_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/buttonSubmitBooking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_gradient_cta_ripple"
                android:elevation="4dp"
                android:minHeight="52dp"
                android:stateListAnimator="@null"
                android:text="@string/booking_submit_request"
                android:textAllCaps="false"
                android:textColor="@color/on_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
