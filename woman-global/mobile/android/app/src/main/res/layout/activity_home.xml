<?xml version="1.0" encoding="utf-8"?>
<!-- Single root + bottom-gravity card: content paints edge-to-edge; only the card is @color/surface. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clipChildren="false"
    tools:context=".HomeActivity">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clipChildren="false"
        android:clipToPadding="false" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavCardContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/bottom_nav_island_margin_horizontal"
        android:layout_marginEnd="@dimen/bottom_nav_island_margin_horizontal"
        android:layout_marginBottom="@dimen/bottom_nav_island_margin_bottom"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="@dimen/bottom_nav_island_corner_radius"
        app:cardElevation="6dp"
        app:strokeColor="@color/outline"
        app:strokeWidth="1dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            style="@style/Widget.ConnectHer.BottomNavigation.Island"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            app:backgroundTint="@android:color/transparent"
            app:elevation="0dp"
            app:itemIconTint="@color/bottom_nav_item_color"
            app:itemTextColor="@color/bottom_nav_item_color"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
