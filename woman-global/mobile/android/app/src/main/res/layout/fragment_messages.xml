<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/messagesMainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/messages_header_title"
                android:textAppearance="@style/TextAppearance.ConnectHer.MessagesScreenTitle" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/messages_header_subtitle"
                android:textAppearance="@style/TextAppearance.ConnectHer.MessagesScreenSubtitle" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/conversationsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="16dp"
            tools:listitem="@layout/item_conversation" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/noMessageLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/noMessageIllustration"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:alpha="0.92"
            android:contentDescription="@string/messages_empty_illustration_cd"
            android:src="@drawable/undraw_messaging" />

        <TextView
            android:id="@+id/noMessageTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.15"
            android:textAppearance="@style/TextAppearance.ConnectHer.MessagesScreenTitle"
            android:text="@string/messages_empty_title" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="@string/messages_empty_body"
            android:textAppearance="@style/TextAppearance.ConnectHer.MessagesScreenSubtitle"
            android:textSize="15sp" />
    </LinearLayout>
</FrameLayout>
