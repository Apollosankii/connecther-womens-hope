<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/chat_thread_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@drawable/bg_chat_header_bar"
        android:elevation="4dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="6dp"
            android:src="@drawable/arrow_back_24px"
            android:tint="@color/on_background"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/userImage"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/circular_clipped_image"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_avatar_neutral"
            app:layout_constraintBottom_toBottomOf="@id/backButton"
            app:layout_constraintStart_toEndOf="@id/backButton"
            app:layout_constraintTop_toTopOf="@id/backButton" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/userImage"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/userImage"
            app:layout_constraintTop_toTopOf="@id/userImage">

            <TextView
                android:id="@+id/userNameTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_background"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Alice Njeri" />

            <TextView
                android:id="@+id/serviceNameTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/chat_text_subtitle"
                android:textSize="12sp"
                android:textStyle="italic"
                tools:text="House Cleaning" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/messageContainer"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        tools:itemCount="10"
        tools:listitem="@layout/item_chat_sent" />

    <LinearLayout
        android:id="@+id/messageContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_composer_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <EditText
            android:id="@+id/messageInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input_inner"
            android:hint="@string/chat_composer_placeholder"
            android:imeOptions="actionSend"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:minHeight="44dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textColor="@color/on_surface"
            android:textColorHint="@color/chat_text_subtitle"
            android:textSize="15sp" />

        <ImageButton
            android:id="@+id/buttonChatMic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_chat_icon_circle"
            android:contentDescription="@string/chat_action_mic"
            android:padding="8dp"
            android:src="@drawable/ic_chat_mic_24" />

        <ImageButton
            android:id="@+id/buttonChatCamera"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_chat_icon_circle"
            android:contentDescription="@string/chat_action_camera"
            android:padding="8dp"
            android:src="@drawable/ic_chat_camera_24" />

        <ImageButton
            android:id="@+id/buttonChatMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_chat_icon_circle"
            android:contentDescription="@string/chat_action_more"
            android:padding="8dp"
            android:src="@drawable/ic_chat_more_24" />

        <ImageButton
            android:id="@+id/sendButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_chat_icon_circle"
            android:contentDescription="@string/chat_action_send"
            android:padding="8dp"
            android:src="@drawable/ic_chat_send_24" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
