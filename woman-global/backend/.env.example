# Copy this file to .env and configure for your environment.
#
# --- Database (required for Alembic and API) ---
# Supabase: Project Settings > Database > Connection string (URI). Use "Session pooler" or "Direct".
#   DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Local:
#   DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/fem_hope
# Docker (host "db"):
#   DATABASE_URL=postgresql+psycopg2://app_user1:DeusVult%2521@db:5432/fem_hope
#
# --- Supabase (Storage + optional DB) ---
# Project URL (for API/Storage). NOT the same as DATABASE_URL.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_JWT_SECRET=your-jwt-secret   # Project Settings > API > JWT Secret (for Admin Portal Supabase Auth)
#
# --- Clerk Auth (optional; if set, API accepts Clerk JWTs and requires clerk_user_id in DB) ---
# JWKS URL from Clerk Dashboard > API Keys > JWT template or use: https://<frontend-api>/.well-known/jwks.json
# CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
#
# --- Legacy JWT (when CLERK_JWKS_URL is not set) ---
# secret=your-secret
# algorithm=HS256
# ACCESS_TOKEN_EXPIRE=30
#
# --- Optional ---
# SQL_ECHO=true   # log SQL (dev only)

DATABASE_URL=postgresql+psycopg2://app_user1:password@localhost:5432/fem_hope
