# Supabase (required – Admin Portal connects directly, no FastAPI)
# Use the SAME project as the Android app (see woman-global/ADMIN_APP_HARMONY.md)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Do NOT use service role. Use only SUPABASE_ANON_KEY. Disable "Confirm email" in Supabase Auth for admin signup.

# Clerk (optional – Admin Portal can use Clerk for sign-in alongside Supabase Auth)
# Same Clerk app as Android. JWT template "supabase" required in Clerk Dashboard.
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# Optional: show detailed 500 errors when developing.
# FLASK_DEBUG=1

# Production (e.g. Vercel): set a random secret for session cookies.
# FLASK_SECRET_KEY=your-random-secret-from-openssl-rand-hex-32
