<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_helpline_card"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Icon circle -->
    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="14dp">

        <View
            android:id="@+id/helplineIconBg"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_icon_circle_pink" />

        <ImageView
            android:id="@+id/helplineIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_phone_call"
            android:tint="@color/primary"
            android:contentDescription="" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/helplineName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Name"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/on_background"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/helplineDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Description"
            android:textSize="12sp"
            android:textColor="@color/on_surface_variant"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/helplineNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="000 000 000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/primary" />
    </LinearLayout>

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_external_link"
        android:contentDescription="Call"
        android:tint="@color/on_surface_variant"
        android:alpha="0.6" />
</LinearLayout>
