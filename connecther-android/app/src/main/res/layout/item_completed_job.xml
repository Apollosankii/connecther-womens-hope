<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="0dp"
    android:layout_marginEnd="0dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/jobTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completed Job #1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/on_background" />

        <TextView
            android:id="@+id/clientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Client: John Doe"
            android:textSize="14sp"
            android:textColor="@color/on_surface_variant" />

        <TextView
            android:id="@+id/serviceName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Service: Cleaning"
            android:textSize="14sp"
            android:textColor="@color/on_surface_variant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/jobPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="KES 2,000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />

            <TextView
                android:id="@+id/jobDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="28 Feb 2024"
                android:textSize="13sp"
                android:textColor="@color/on_surface_variant" />
        </LinearLayout>

        <RatingBar
            android:id="@+id/jobRatingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:numStars="5"
            android:stepSize="0.5"
            android:rating="0"
            android:isIndicator="true"
            android:visibility="gone"
            android:secondaryProgressTint="@color/star_yellow"
            style="@style/Widget.AppCompat.RatingBar.Small" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/rateJobButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:text="Rate job"
            android:textAllCaps="false"
            android:textSize="14sp"
            app:backgroundTint="@color/primary"
            android:textColor="@color/on_primary"
            android:visibility="gone"
            app:cornerRadius="10dp" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
